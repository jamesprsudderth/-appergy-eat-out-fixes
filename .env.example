# ─── Appergy Environment Variables ───
#
# Copy this to .env and fill in your values.
# Restart Expo after changes: npm run expo:dev
#
# SERVER ENV VARS (set in Railway/Cloud Run dashboard → Variables):
#   OPENAI_API_KEY=sk-...
#   PORT=5000  (Railway sets this; Cloud Run injects 8080 automatically)
#
#   FIREBASE_SERVICE_ACCOUNT='{...}'
#     Required for Firebase Admin SDK (verifies ID tokens on every /api route).
#     Value is the service account JSON as a single-line string.
#     On Cloud Run: store in Secret Manager as "firebase-service-account".
#     On Railway: paste the minified JSON into the Variables panel.
#     Locally: omit and run `gcloud auth application-default login`, OR paste the
#              JSON into your .env (never commit .env).
#
# CLIENT ENV VARS (set in this .env file locally):

# ── Your Railway server URL (NO https://, NO trailing slash) ──
# After deploying to Railway, get the URL from Settings → Domains
# Example: appergy-production.up.railway.app
EXPO_PUBLIC_DOMAIN=your-app.up.railway.app

# ── Firebase ──
# Hardcoded fallbacks exist for appergy-24baa, override here if needed
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=appergy-24baa

# ── Google Places (for Nearby Restaurants) ──
# EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# ── Firebase App Check debug token ──
# Only needed for local development / CI (simulators can't use DeviceCheck or Play Integrity).
# How to get it:
#   1. Run the app in __DEV__ mode on a simulator or Expo Go.
#   2. RNFB prints a token like "AppCheck debug token: XXXXXXXX-..." to the console.
#   3. Register that token in Firebase Console → App Check → [your app] → Manage debug tokens.
#   4. Paste it here so the same token is used across all dev sessions.
# EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
